{
  "name": "solo-college‑planner",
  "version": "1.0.0",
  "description": "Reach/Target/Safety college planner with CSV data, Express API, and a Vite React frontend",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev:api": "nodemon backend/server.js",
    "dev:web": "vite",
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "build": "vite build",
    "preview": "vite preview",
    "import:csv": "node backend/imports/run-import.mjs",
    "supabase:import-schools": "node backend/imports/run-import.mjs schools"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "express": "^4.18.2",
    "csvtojson": "^2.0.10",
    "@supabase/supabase-js": "^2.57.4",
    "lucide-react": "^0.542.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.1",
    "nodemon": "^2.0.22",
    "vite": "^7.0.0"
  }
}
